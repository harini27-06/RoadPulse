# Set these in your Render dashboard under Environment Variables
# DO NOT put real values here

DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.neon.tech/roadwatch?sslmode=require&pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://USER:PASSWORD@HOST.neon.tech/roadwatch?sslmode=require
JWT_SECRET=change-this-to-a-random-secret
GEMINI_API_KEY=your-gemini-api-key
YOLO_SERVICE_URL=https://your-yolo-service.onrender.com
RESEND_API_KEY=your-resend-api-key
ADMIN_EMAIL=your-admin-email@example.com
NODE_ENV=production
